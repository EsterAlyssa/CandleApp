# Environment configuration for CandleApp
# NOTE: This file is read at runtime from the client (if served) to populate env variables.
# Do not store secrets here if deploying publicly.

# Base Cloudinary URL (required):
NEXT_PUBLIC_CLOUDINARY_BASE_URL=https://res.cloudinary.com/dtkrxt96q/image/upload/candle_app_images/

# Preset unsigned (richiesto per l’upload dal browser)
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=candle_app
